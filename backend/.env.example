GEMINI_API_KEY=your_gemini_api_key_here
# Local development default (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vambe
# On Railway this is set automatically by the PostgreSQL addon
FRONTEND_URL=http://localhost:5173
CSV_PATH=vambe_clients.csv
# Comma-separated list of allowed CORS origins (defaults to localhost:5173)
# ALLOWED_ORIGINS=["https://your-app.vercel.app","http://localhost:5173"]
# API key to protect POST /api/process (optional — if unset, endpoint is open)
# PROCESS_API_KEY=your_secret_key_here
